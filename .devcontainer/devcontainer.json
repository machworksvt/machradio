{
  "name": "machradio",
  "dockerComposeFile": [
    "../docker-compose.yml"
  ],
  "service": "dev",
  "workspaceFolder": "/workspace",
  "shutdownAction": "stopCompose",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.cpptools",
        "ms-vscode.cmake-tools",
        "ms-iot.vscode-ros"
      ],
      "settings": {
        "cmake.buildDirectory": "${workspaceFolder}/build",
        "C_Cpp.default.compileCommands": "${workspaceFolder}/build/compile_commands.json"
      }
    }
  }
}
